{
  "name": "streaming-agents",
  "version": "0.0.1",
  "private": true,
  "description": "Streaming Agents monorepo – real-time telemetry, AI-powered incident management",
  "scripts": {
    "dev": "pnpm -r --parallel run dev",
    "build": "pnpm -r run build",
    "test": "pnpm -r run test",
    "clean": "pnpm -r run clean",
    "format": "biome format . --write",
    "lint": "biome lint .",
    "check": "biome check .",
    "check:write": "biome check . --write",
    "check:changed": "biome check --changed --write"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/node": "^22.0.0",
    "esbuild": "^0.27.3",
    "tsx": "^4.19.0",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "packageManager": "pnpm@9.15.4"
}
