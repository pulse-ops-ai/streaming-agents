{
  "name": "@streaming-agents/core-kinesis",
  "version": "0.1.0",
  "private": true,
  "description": "Kinesis producer/consumer wrappers with DLQ routing for Lambda services",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rm -rf dist",
    "test": "vitest run"
  },
  "dependencies": {
    "@aws-sdk/client-kinesis": "^3.700.0",
    "@aws-sdk/client-sqs": "^3.700.0",
    "@streaming-agents/core-contracts": "workspace:*",
    "@streaming-agents/core-telemetry": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.9.3",
    "vitest": "^3.0.0"
  }
}
