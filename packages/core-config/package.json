{
  "name": "@streaming-agents/core-config",
  "version": "0.1.0",
  "private": true,
  "description": "Zod-validated environment variable loading with environment-aware secret resolution",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rm -rf dist",
    "test": "vitest run"
  },
  "dependencies": {
    "zod": "^3.24.0"
  },
  "optionalDependencies": {
    "@aws-sdk/client-secrets-manager": "^3.700.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.9.3",
    "vitest": "^3.0.0"
  }
}
