{
  "$ref": "#/definitions/r17-telemetry-v2",
  "definitions": {
    "r17-telemetry-v2": {
      "type": "object",
      "properties": {
        "schema_version": {
          "type": "string",
          "const": "r17.telemetry.v2"
        },
        "event_id": {
          "type": "string",
          "minLength": 1
        },
        "asset_id": {
          "type": "string",
          "const": "r-17"
        },
        "timestamp": {
          "type": "string",
          "format": "date-time"
        },
        "source": {
          "type": "string",
          "enum": ["simulator", "reachy-daemon", "reachy-sdk", "reachy-exporter", "replay"]
        },
        "sequence": {
          "type": "integer",
          "minimum": 0
        },
        "sampling_hz": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "joint_position_error_deg": {
          "type": "number",
          "minimum": 0
        },
        "board_temperature_c": {
          "type": ["number", "null"],
          "default": null
        },
        "accel_magnitude_ms2": {
          "anyOf": [
            {
              "type": "number",
              "minimum": 0
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "gyro_magnitude_rads": {
          "anyOf": [
            {
              "type": "number",
              "minimum": 0
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "control_mode": {
          "anyOf": [
            {
              "type": "string",
              "enum": ["idle", "compliant", "stiff", "unknown"]
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "control_loop_stats": {
          "anyOf": [
            {
              "type": "object",
              "properties": {
                "freq_hz": {
                  "type": "number",
                  "minimum": 0
                },
                "max_interval_ms": {
                  "type": "number",
                  "minimum": 0
                },
                "error_count": {
                  "type": "integer",
                  "minimum": 0
                }
              },
              "required": ["freq_hz", "max_interval_ms", "error_count"],
              "additionalProperties": false
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "error_code": {
          "type": ["string", "null"],
          "default": null
        }
      },
      "required": [
        "schema_version",
        "event_id",
        "asset_id",
        "timestamp",
        "source",
        "sequence",
        "sampling_hz",
        "joint_position_error_deg"
      ],
      "additionalProperties": false
    }
  },
  "$schema": "http://json-schema.org/draft-07/schema#"
}
