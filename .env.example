# ── AWS / LocalStack ──────────────────────────────────
AWS_REGION=us-east-1
AWS_PROFILE=streaming-agents-sandbox
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
LOCALSTACK_ENDPOINT=http://localhost:4566
LOCALSTACK_AUTH_TOKEN=<your-key>
LOCALSTACK_VOLUME_DIR=./docker/localstack

# ── Lambda Executor ───────────────────────────────────
# local = fast, in-process (recommended for dev)
# docker = isolated, one container per invocation (production-like)
LAMBDA_EXECUTOR=local

# ── Simulator Overrides ───────────────────────────────
# Fixed worker count (unset = hourly schedule 5-50 workers)
SIM_WORKER_COUNT=2
# Events per worker per invocation (default: 120)
SIM_BURST_COUNT=10

# ── LLM Providers ────────────────────────────────────
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
BEDROCK_REGION=us-east-1

# ── Database ─────────────────────────────────────────
DYNAMODB_TABLE_PREFIX=streaming-agents

# ── Observability ────────────────────────────────────
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
LOG_LEVEL=debug

# ── Dashboard Local Compose (.local.yml) ─────────────
PORT=3000
NODE_ENV=dev
DYNAMODB_HISTORY_TABLE=streaming-agents-asset-history
DYNAMODB_ASSET_STATE_TABLE=streaming-agents-asset-state
DYNAMODB_INCIDENTS_TABLE=streaming-agents-incidents
