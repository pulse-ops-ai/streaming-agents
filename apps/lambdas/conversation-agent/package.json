{
  "name": "@streaming-agents/conversation-agent",
  "version": "0.1.0",
  "description": "Amazon Lex V2 fulfillment Lambda for the streaming agents copilot",
  "private": true,
  "type": "module",
  "main": "dist/main.js",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "clean": "rm -rf dist tsconfig.tsbuildinfo",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@aws-sdk/client-bedrock-runtime": "^3.750.0",
    "@aws-sdk/client-dynamodb": "^3.750.0",
    "@aws-sdk/lib-dynamodb": "^3.750.0",
    "@nestjs/common": "^10.0.0",
    "@nestjs/config": "^4.0.3",
    "@nestjs/core": "^10.0.0",
    "@streaming-agents/core-config": "workspace:*",
    "@streaming-agents/core-contracts": "workspace:*",
    "@streaming-agents/core-telemetry": "workspace:*",
    "aws-lambda": "^1.0.7"
  },
  "devDependencies": {
    "@aws-sdk/client-polly": "^3.750.0",
    "@biomejs/biome": "^1.9.4",
    "@types/aws-lambda": "^8.10.147",
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^3.2.4",
    "reflect-metadata": "^0.2.0",
    "typescript": "^5.7.3",
    "vitest": "^3.0.0"
  }
}
