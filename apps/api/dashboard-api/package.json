{
  "name": "@streaming-agents/dashboard-api",
  "version": "0.1.0",
  "description": "NestJS HTTP API serving dashboard read endpoints backed by DynamoDB",
  "private": true,
  "type": "module",
  "main": "dist/main.js",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "clean": "rm -rf dist",
    "start": "node dist/main.js",
    "start:dev": "tsx watch src/main.ts",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@aws-sdk/client-cloudwatch-logs": "^3.750.0",
    "@aws-sdk/client-dynamodb": "^3.750.0",
    "@aws-sdk/client-eventbridge": "^3.750.0",
    "@aws-sdk/client-lambda": "^3.750.0",
    "@aws-sdk/lib-dynamodb": "^3.750.0",
    "@nestjs/common": "^10.0.0",
    "@nestjs/config": "^4.0.3",
    "@nestjs/core": "^10.0.0",
    "@nestjs/platform-express": "^10.0.0",
    "@streaming-agents/core-contracts": "workspace:*",
    "@streaming-agents/domain-models": "workspace:*",
    "reflect-metadata": "^0.2.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.3",
    "vitest": "^3.0.0"
  }
}
